# ─────────────────────────────────────────────────────────────
# DietTrace .gitignore
# ─────────────────────────────────────────────────────────────

# --- Secrets (NEVER commit) ---
.env
.env.*
!.env.example
*.pem
*-key.json
service-account*.json

# --- Python ---
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
build/
dist/

# --- Deploy context ---
.gcloudignore
frontend/.gcloudignore
cloudbuild*.yaml
deploy*.sh

# --- Nutrition data & DB implementation (obscured; sourced from USDA FDC, see README) ---
data/
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
*.dump
*.sql
src/dietrace/nutrition/mappings/
src/dietrace/nutrition/schema.sql

# --- Frontend build artifacts ---
frontend/node_modules/
frontend/dist/
frontend/.next/
src/dietrace/web/static/assets/

# --- OS / editor ---
.DS_Store
.idea/
.vscode/
*.log

# stray root node_modules (vitest cache) — never track
node_modules/
