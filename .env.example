# DietTrace environment — copy to .env and fill in. NEVER commit .env.

# --- Gemini (Vertex AI) ---
DIETRACE_GEMINI_PROJECT=your-gcp-project-id
DIETRACE_GEMINI_LOCATION=global  # Gemini 3 preview is served from "global", not a region
DIETRACE_GEMINI_MODEL=gemini-3.1-pro-preview

# --- Arize Phoenix (Cloud free tier; keeps spans off the GCP budget) ---
PHOENIX_API_KEY=your-phoenix-api-key
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/<workspace-slug>/v1/traces
PHOENIX_BASE_URL=https://app.phoenix.arize.com

# --- GitHub (supervisor opens PRs; needs repo scope) ---
GITHUB_TOKEN=your-github-pat

# --- USDA FoodData Central (only needed for live API fallback; bulk data is offline) ---
FDC_API_KEY=

# --- Food DB (local read-only SQLite baked into the image at deploy) ---
DIETRACE_FOOD_DB=data/food.sqlite

# --- Firebase Auth (optional: enables Google sign-in; anon-only if unset) ---
# Backend: the Firebase project id used as the ID-token audience. Defaults to
# GOOGLE_CLOUD_PROJECT / DIETRACE_GEMINI_PROJECT if unset, so usually no need to
# set this separately when Firebase lives in the same GCP project.
DIETRACE_FIREBASE_PROJECT=your-gcp-project-id
#
# Frontend (set these in frontend/.env.local, NEXT_PUBLIC_* so they reach the
# browser): Firebase console → Project settings → your Web app → SDK config.
# NEXT_PUBLIC_FIREBASE_API_KEY=...
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-gcp-project-id
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=...
# NEXT_PUBLIC_FIREBASE_APP_ID=...
